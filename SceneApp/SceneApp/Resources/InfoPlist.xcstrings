  "sourceLanguage": "en",
  "strings": {
    "NSCalendarsUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Scene uses your calendar to activate Workspaces automatically when matching events begin."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "Scene 會用你嘅日曆，喺配對到嘅事件開始時自動啟動情境。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "Scene 會使用您的行事曆,在符合條件的事件開始時自動啟動工作空間。"
          }
        }
      }
    }
  },
  "version": "1.0"
}
