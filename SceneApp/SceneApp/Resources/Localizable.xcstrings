    "onboarding.calendar.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Scene needs calendar access to fire calendar-based Workspace triggers."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "Scene 需要存取日曆先可以喺事件開始時自動啟動情境。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "Scene 需要存取行事曆,才能在事件開始時觸發工作空間。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カレンダーを使ったワークスペーストリガーを実行するため、Scene はカレンダーへのアクセスが必要です。"
          }
        }
      }
    },
