    "onboarding.accessibility.still_not_detected.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If you upgraded from Scene v0.4.3 or earlier, macOS may require you to re-authorize Accessibility because Scene is now notarized by Apple (a different signature lineage). This is a one-time step — future v0.5.0+ updates will preserve your grant automatically. Reset with the command below, then relaunch Scene and re-authorize."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "如果你由 Scene v0.4.3 或更早版本升級上嚟，macOS 可能要求你重新授權輔助使用，因為 Scene 已經由 Apple notarize（簽名方式唔同咗）。呢個係一次性步驟 — 以後 v0.5.0+ 嘅更新會自動保留授權。用下面嘅指令 reset，然後重啟 Scene 再重新授權。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "如果你從 Scene v0.4.3 或更早版本升級而來，macOS 可能要求你重新授權輔助使用，因為 Scene 現已由 Apple notarize（簽名方式不同）。這是一次性步驟 — 未來 v0.5.0+ 的更新會自動保留授權。用下方指令重設，再重新啟動 Scene 並重新授權。"
          }
        }
      }
    },
    "onboarding.accessibility.copy_command": {
