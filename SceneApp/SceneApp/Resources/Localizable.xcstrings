          }
        }
      }
    },
    "onboarding.accessibility.still_not_detected.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If Scene is already in the Accessibility list, toggle it OFF then back ON — macOS requires re-confirming access after each update. If that fails, quit Scene and reopen."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "如果 Scene 已經喺輔助使用 list 入面，撳個 toggle OFF 再撳 ON — macOS 每次升級都要 confirm 多次權限。如果仲係唔得，結束 Scene 再開過。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "如果 Scene 已在輔助使用清單中，請把開關切到 OFF 再切回 ON — macOS 每次更新後都需重新確認權限。仍無法偵測請結束 Scene 再開啟。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクセシビリティのリストに Scene がすでにある場合は、スイッチを一度 OFF にしてから再度 ON にしてください（macOS はアップデートごとに権限の再確認が必要です）。それでもだめな場合は Scene を終了して開き直してください。"
          }
        }
      }
    },
    "onboarding.accessibility.still_not_detected.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Still not detected?"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "仲係偵測唔到？"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "仍然無法偵測?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まだ検出されませんか?"
          }
        }
      }
    },
