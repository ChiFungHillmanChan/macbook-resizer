    "onboarding.accessibility.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "To resize and rearrange your windows, Scene needs permission to control other apps.\n\nClick below to open System Settings, then enable Scene under Privacy & Security → Accessibility.\n\nAlready granted? After each update, toggle Scene OFF then ON to refresh the grant."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "要重新調整同排視窗，Scene 要有權限控制其他 App。\n\n撳下面嘅掣開「系統設定」，喺「私隱與保安 → 輔助使用」度打開 Scene。\n\n已經畀咗權限？每次升級 Scene 之後，撳 toggle OFF 再撳 ON 先會認到新版本。"
          }
        },
        "zh-TW": {
          "stringUnit": {
            "state": "translated",
            "value": "為了調整並重新排列視窗，Scene 需要控制其他 App 的權限。\n\n請按下方按鈕開啟「系統設定」，並在「隱私權與安全性 → 輔助使用」中啟用 Scene。\n\n已經授權？每次更新 Scene 後，請把開關切到 OFF 再切回 ON 以重新確認。"
          }
        }
      }
    },
    "onboarding.accessibility.check_again": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
